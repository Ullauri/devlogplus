# =============================================================================
# DevLog+ Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://devlogplus:devlogplus@db:5432/devlogplus

# --- OpenRouter (LLM API) ---------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Langfuse (LLM Observability) -------------------------------------------
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# --- LLM Model Selection Per Pipeline ---------------------------------------
# Each pipeline can use a different model via OpenRouter.
# Format: <provider>/<model-name>
LLM_MODEL_TOPIC_EXTRACTION=anthropic/claude-sonnet-4-20250514
LLM_MODEL_PROFILE_UPDATE=anthropic/claude-sonnet-4-20250514
LLM_MODEL_QUIZ_GENERATION=anthropic/claude-sonnet-4-20250514
LLM_MODEL_QUIZ_EVALUATION=anthropic/claude-sonnet-4-20250514
LLM_MODEL_READING_GENERATION=anthropic/claude-sonnet-4-20250514
LLM_MODEL_PROJECT_GENERATION=anthropic/claude-sonnet-4-20250514
LLM_MODEL_PROJECT_EVALUATION=anthropic/claude-sonnet-4-20250514

# --- Application Settings ---------------------------------------------------
QUIZ_QUESTION_COUNT=10
READING_RECOMMENDATION_COUNT=5
APP_ENV=development
LOG_LEVEL=INFO
